function openDashboard() {
  var cfg = getConfig_();
  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var buckets = computeBuckets_(cfg, data);

  // Scans reuse.
  var queueMap = buildQueueMap_(cfg);
  var pendingAssessment = [], readyInterview = [], readyOffering = [];
  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    var name = String(row[COLUMNS.NAME - 1]).trim(); if (name === "") continue;
    var verdict = String(row[COLUMNS.VERDICT - 1]).trim(), verdictL = verdict.toLowerCase();
    var assess = String(row[COLUMNS.ASSESSMENT - 1]).trim(), assessL = assess.toLowerCase();
    var mgrAttend = String(row[COLUMNS.MGR_ATTEND - 1]).trim(), mgrStatus = String(row[COLUMNS.MGR_STATUS - 1]).trim();
    var phone = String(row[COLUMNS.PHONE - 1]).trim(), reviewer = String(row[COLUMNS.REVIEWER - 1]).trim();
    var toOffers = String(row[COLUMNS.TO_OFFERS - 1]).trim();
    var offerResult = String(row[COLUMNS.OFFER_RESULT - 1]).trim(), offerNotes = String(row[COLUMNS.OFFER_NOTES - 1]).trim();

    if (verdict.toLowerCase().indexOf(STATUS.VERDICT_PASS_TOKEN) !== -1 && assess === STATUS.ASSESS_NOT_DONE)
      pendingAssessment.push({ name: name, reviewer: reviewer, phone: phone });

    var attendBlank = mgrAttend === "" || mgrAttend === "-", statusBlank = mgrStatus === "" || mgrStatus === "-";
    if (verdictL.indexOf(STATUS.VERDICT_PASS_TOKEN) !== -1 && STATUS.ASSESS_PASS.indexOf(assessL) !== -1 && attendBlank && statusBlank) {
      var qe = queueMap[norm_(name)];
      if (!(qe && qe.processed === "Done")) readyInterview.push({ name: name, reviewer: reviewer, phone: phone, assignedTo: (qe && qe.assignee !== "") ? qe.assignee : "⚠ Unassigned" });
    }
    if (STATUS.STAGE2_PASS_STATUSES.indexOf(mgrStatus) !== -1 && offerResult === "" && offerNotes === "")
      readyOffering.push({ name: name, reviewer: reviewer, phone: phone, status: mgrStatus, notified: toOffers === "" ? "Not yet" : "Notified" });
  }

  var weeks = buildWeekly_(cfg, data);

  var css = "body{font-family:Arial,sans-serif;margin:0;background:#f4f6f8;}.header{background:#2c3e50;color:#fff;padding:16px 24px;}.header h1{margin:0;font-size:20px;}.header p{margin:4px 0 0;font-size:12px;opacity:.8;}.tabs{display:flex;background:#34495e;padding:0 16px;overflow-x:auto;}.tab{padding:12px 20px;color:#bdc3c7;cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;font-size:13px;}.tab:hover{background:#2c3e50;color:#fff;}.tab.active{color:#fff;border-bottom-color:#3498db;background:#2c3e50;}.content{padding:20px 24px;}.panel{display:none;}.panel.active{display:block;}h2{margin:0 0 12px;font-size:18px;color:#2c3e50;}h3{margin:20px 0 8px;font-size:14px;color:#34495e;}table{border-collapse:collapse;margin-top:8px;font-size:13px;background:#fff;}th,td{padding:6px 10px;border:1px solid #ddd;text-align:left;}th{background:#ecf0f1;font-weight:bold;}tr:nth-child(even) td{background:#fafafa;}.funnel-cell{text-align:center;}.conv{color:#27ae60;font-size:11px;}.drop{font-size:11px;}.drop.warn{color:#e67e22;font-weight:bold;}.drop.bad{color:#dc3545;font-weight:bold;}.stat-card{background:#fff;padding:12px 16px;border-left:4px solid #3498db;margin-top:8px;}.empty{color:#888;font-style:italic;padding:12px;}.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:bold;margin-left:8px;}.badge-green{background:#d4edda;color:#155724;}.badge-yellow{background:#fff3cd;color:#856404;}.badge-red{background:#f8d7da;color:#721c24;}.group-header{background:#e3f0fc;padding:8px 12px;margin-top:16px;font-weight:bold;border-left:4px solid #3498db;}";

  var html = "<!DOCTYPE html><html><head><style>" + css + "</style></head><body>";
  html += "<div class='header'><h1>Recruiter Dashboard</h1><p>Snapshot as of " + getCurrentTime_() + "</p></div>";
  html += "<div class='tabs'><div class='tab active' onclick=\"showTab(event,'pipeline')\">Pipeline</div><div class='tab' onclick=\"showTab(event,'assess')\">Pending Assessment (" + pendingAssessment.length + ")</div><div class='tab' onclick=\"showTab(event,'interview')\">Ready for Interview (" + readyInterview.length + ")</div><div class='tab' onclick=\"showTab(event,'offering')\">Ready for Offering (" + readyOffering.length + ")</div><div class='tab' onclick=\"showTab(event,'health')\">Health</div></div><div class='content'>";

  // Pipeline
  html += "<div id='pipeline' class='panel active'><h2>Recruitment Pipeline</h2><p style='color:#666;font-size:12px;'>Cumulative, excluding legacy rows.</p>";
  html += "<h3>By Role</h3>" + buildDashFunnel_([
    { label: "General", counts: buckets.roleGeneral, color: "#e3f0fc" },
    { label: ROLE.CERTIFIED, counts: buckets.roleCertified, color: "#d4edda" },
    { label: "TOTAL", counts: buckets.total, color: "#fff3cd" },
  ]);
  html += "<h3>By Channel</h3>" + buildDashFunnel_([
    { label: "Channel A", counts: buckets.channelA, color: "#e8daef" },
    { label: "Channel B", counts: buckets.channelB, color: "#fadbd8" },
  ]) + "</div>";

  html += buildDashScanPanel_("assess", "Pending Assessment", pendingAssessment, "reviewer", ["name", "phone"], ["Name", "Contact"]);
  html += buildDashScanPanel_("interview", "Ready for Interview", readyInterview, "assignedTo", ["name", "phone", "reviewer"], ["Name", "Contact", "Reviewer"]);
  html += buildDashScanPanel_("offering", "Ready for Offering", readyOffering, null, ["name", "phone", "reviewer", "status", "notified"], ["Name", "Contact", "Reviewer", "Stage-2 Status", "Notified"]);

  // Health
  html += "<div id='health' class='panel'><h2>Interview Health Check-up</h2>";
  if (weeks.length < 2) html += "<div class='empty'>Not enough weekly data yet.</div>";
  else {
    var curKey = weekKeyOf_(new Date());
    var completed = weeks.filter(function (w, idx) { return w.key !== curKey && idx !== 0; });
    var bestW = completed[0], worstW = completed[0], tc = 0, ti = 0;
    completed.forEach(function (w) { if (w.candidates > bestW.candidates) bestW = w; if (w.candidates < worstW.candidates) worstW = w; tc += w.candidates; ti += w.reviewerCount; });
    var lastW = completed[completed.length - 1];
    var st = classifyWeek_(lastW.candidates, lastW.reviewerCount, lastW.reviewerCount > 0 ? lastW.candidates / lastW.reviewerCount : 0);
    html += "<div style='background:" + st.color + ";color:#fff;padding:14px 18px;border-radius:4px;margin:12px 0;'><strong style='font-size:16px;'>" + st.label.toUpperCase() + "</strong><br><span style='font-size:13px;'>Last week: " + lastW.candidates + " interviews by " + lastW.reviewerCount + " reviewer(s)</span></div>";
    html += "<div class='stat-card'><strong>Avg candidates/week:</strong> " + (tc / completed.length).toFixed(1) + "</div>";
    html += "<div class='stat-card' style='border-color:#27ae60;'><strong>Best week:</strong> " + Utilities.formatDate(bestW.start, Session.getScriptTimeZone(), "dd MMM yyyy") + " — " + bestW.candidates + "</div>";
    html += "<div class='stat-card' style='border-color:#dc3545;'><strong>Worst week:</strong> " + Utilities.formatDate(worstW.start, Session.getScriptTimeZone(), "dd MMM yyyy") + " — " + worstW.candidates + "</div>";
    html += "<h3>Week-by-Week</h3><table><tr><th>Week</th><th>Candidates</th><th>Reviewers</th><th>Avg</th><th>Status</th></tr>";
    weeks.forEach(function (w, idx) {
      var ap = w.reviewerCount > 0 ? w.candidates / w.reviewerCount : 0, sl, sc;
      if (w.key === curKey) { sl = "In Progress"; sc = "#888"; }
      else if (idx === 0) { sl = "Ramp-up"; sc = "#888"; }
      else { var c = classifyWeek_(w.candidates, w.reviewerCount, ap); sl = c.label; sc = c.color; }
      html += "<tr><td>" + Utilities.formatDate(w.start, Session.getScriptTimeZone(), "dd MMM yyyy") + "</td><td><strong>" + w.candidates + "</strong></td><td>" + w.reviewerCount + "</td><td>" + ap.toFixed(1) + "</td><td style='color:" + sc + ";font-weight:bold;'>" + sl + "</td></tr>";
    });
    html += "</table>";
  }
  html += "</div>";

  html += "</div><script>function showTab(e,id){var p=document.querySelectorAll('.panel'),t=document.querySelectorAll('.tab');for(var i=0;i<p.length;i++)p[i].classList.remove('active');for(var j=0;j<t.length;j++)t[j].classList.remove('active');document.getElementById(id).classList.add('active');e.currentTarget.classList.add('active');}</script></body></html>";

  var out = HtmlService.createHtmlOutput(html).setWidth(1200).setHeight(750).setTitle("Recruiter Dashboard");
  SpreadsheetApp.getUi().showModelessDialog(out, "Recruiter Dashboard");
}

function buildDashScanPanel_(id, title, rows, groupKey, cols, headers) {
  var html = "<div id='" + id + "' class='panel'><h2>" + title + " <span class='badge badge-yellow'>" + rows.length + "</span></h2>";
  if (rows.length === 0) return html + "<div class='empty'>Nothing here.</div></div>";

  function tableFor(list) {
    var t = "<table><tr><th>#</th>";
    headers.forEach(function (h) { t += "<th>" + h + "</th>"; });
    t += "</tr>";
    list.forEach(function (r, i) {
      t += "<tr><td>" + (i + 1) + "</td>";
      cols.forEach(function (c) { t += "<td>" + (r[c] || "") + "</td>"; });
      t += "</tr>";
    });
    return t + "</table>";
  }

  if (groupKey) {
    var grouped = groupBy_(rows, groupKey);
    for (var g in grouped) { if (!grouped.hasOwnProperty(g)) continue; html += "<div class='group-header'>" + g + " (" + grouped[g].length + ")</div>" + tableFor(grouped[g]); }
  } else {
    html += tableFor(rows);
  }
  return html + "</div>";
}

function buildDashFunnel_(sections) {
  var short = [
    { key: "applicant", label: "Applicant" }, { key: "responded", label: "Responded" },
    { key: "passedScreening", label: "Pass Screen" }, { key: "assessDone", label: "Assess Done" },
    { key: "assessPassed", label: "Assess Pass" }, { key: "sentStage2", label: "Sent S2" },
    { key: "stage2Passed", label: "S2 Pass" }, { key: "offered", label: "Offered" }, { key: "accepted", label: "Accepted" },
  ];
  var html = "<table><tr><th></th>";
  short.forEach(function (s) { html += "<th>" + s.label + "</th>"; });
  html += "</tr>";
  sections.forEach(function (section) {
    var counts = section.counts;
    html += "<tr><td style='background:" + section.color + ";font-weight:bold;' rowspan='3'>" + section.label + "</td>";
    short.forEach(function (s) { html += "<td class='funnel-cell'><strong>" + (counts[s.key] || 0) + "</strong></td>"; });
    html += "</tr><tr>";
    short.forEach(function (s, i) {
      if (i === 0) { html += "<td class='funnel-cell'>—</td>"; return; }
      var prev = counts[short[i - 1].key] || 0, curr = counts[s.key] || 0;
      html += "<td class='funnel-cell conv'>↑ " + (prev === 0 ? "N/A" : ((curr / prev) * 100).toFixed(1) + "%") + "</td>";
    });
    html += "</tr><tr>";
    short.forEach(function (s, i) {
      if (i === 0) { html += "<td class='funnel-cell'>—</td>"; return; }
      var prev = counts[short[i - 1].key] || 0, curr = counts[s.key] || 0;
      if (prev === 0) { html += "<td class='funnel-cell'>N/A</td>"; return; }
      var dv = ((prev - curr) / prev) * 100, cls = "drop";
      if (dv > 50) cls = "drop bad"; else if (dv > 30) cls = "drop warn";
      html += "<td class='funnel-cell " + cls + "'>↓ " + dv.toFixed(1) + "%</td>";
    });
    html += "</tr>";
  });
  return html + "</table>";
}
