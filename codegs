// PROCESSING: Stage 1 → Review Queue  (round-robin assignment)
// ════════════════════════════════════════════════════════════
//
// The lookup formulas below use an EXAMPLE column layout on the applicants
// sheet (contact in column Y, assessment in column AB). This is a
// demonstration schema, not production. Whoever adapts this template must
// remap the column letters to their own sheet.

function buildQueueMap_(cfg) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var queueSheet = ss.getSheetByName(cfg.SHEET_QUEUE);
  var map = {};
  if (!queueSheet) return map;
  var lastRow = findLastRowByColumn_(queueSheet, 1);
  var rows = lastRow >= 2 ? queueSheet.getRange(2, 1, lastRow - 1, 8).getValues() : [];
  rows.forEach(function (r) {
    var n = norm_(r[0]);
    if (n !== "") map[n] = { processed: String(r[5]).trim(), assignee: String(r[6]).trim() };
  });
  return map;
}

function processStage1ToQueue() {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var queueSheet = ss.getSheetByName(cfg.SHEET_QUEUE);
  if (!queueSheet) { ui.alert("Sheet '" + cfg.SHEET_QUEUE + "' not found."); return; }

  var queueMap = buildQueueMap_(cfg);
  var unassigned = [];
  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    var verdict = String(row[COLUMNS.VERDICT - 1]).trim().toLowerCase();
    var assess = String(row[COLUMNS.ASSESSMENT - 1]).trim().toLowerCase();
    var mgrAttend = String(row[COLUMNS.MGR_ATTEND - 1]).trim();
    var mgrStatus = String(row[COLUMNS.MGR_STATUS - 1]).trim();
    var attendBlank = mgrAttend === "" || mgrAttend === "-";
    var statusBlank = mgrStatus === "" || mgrStatus === "-";
    if (verdict.indexOf(STATUS.VERDICT_PASS_TOKEN) !== -1 && STATUS.ASSESS_PASS.indexOf(assess) !== -1 && attendBlank && statusBlank) {
      var name = String(row[COLUMNS.NAME - 1]).trim();
      if (queueMap[norm_(name)]) continue;
      unassigned.push(name);
    }
  }
  if (unassigned.length === 0) { ui.alert("No unassigned candidates. All already in the review queue."); return; }

  var roster = getRoster_();
  var interviewers = Object.keys(roster.interviewMap);
  if (interviewers.length === 0) { ui.alert("No active interviewers in the roster (Stage='Interview', Active='YES')."); return; }

  // Current backlog per interviewer (Not Yet in queue).
  var lastRow = findLastRowByColumn_(queueSheet, 1);
  var queueRows = lastRow >= 2 ? queueSheet.getRange(2, 1, lastRow - 1, 8).getValues() : [];
  var backlog = {};
  interviewers.forEach(function (n) { backlog[n] = 0; });
  queueRows.forEach(function (r) {
    var assignee = String(r[6]).trim(), processed = String(r[5]).trim();
    if (assignee in backlog && processed === "Not Yet") backlog[assignee]++;
  });

  var assignments = [];
  unassigned.forEach(function (candidate) {
    var minInt = interviewers[0], minCount = backlog[minInt];
    for (var f = 1; f < interviewers.length; f++) {
      if (backlog[interviewers[f]] < minCount) { minCount = backlog[interviewers[f]]; minInt = interviewers[f]; }
    }
    assignments.push({ name: candidate, interviewer: minInt });
    backlog[minInt]++;
  });

  var summary = {};
  assignments.forEach(function (a) { summary[a.interviewer] = (summary[a.interviewer] || 0) + 1; });
  var preview = "Found " + unassigned.length + " unassigned candidate(s).\n\nAssignment preview:\n";
  Object.keys(summary).forEach(function (k) { preview += "  " + k + ": " + summary[k] + "\n"; });
  preview += "\nWrite " + unassigned.length + " row(s) to '" + cfg.SHEET_QUEUE + "'?";
  if (ui.alert("Process: Stage 1 → Review Queue", preview, ui.ButtonSet.YES_NO) !== ui.Button.YES) return;

  var startRow = lastRow + 1;
  var today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd MMM yyyy");
  var A = q_(cfg.SHEET_APPLICANTS), IMP = q_(cfg.SHEET_IMPORT), S2 = q_(cfg.SHEET_STAGE2);

  for (var a = 0; a < assignments.length; a++) {
    var rowNum = startRow + a, cand = assignments[a].name, intName = assignments[a].interviewer;
    queueSheet.getRange(rowNum, 1).setValue(cand);
    // Column D: contact lookup (EXAMPLE: applicants column Y).
    queueSheet.getRange(rowNum, 4).setFormula(
      "=IFERROR(ARRAYFORMULA(INDEX(" + A + "!Y:Y,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(A" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))),\"\")");
    // Column E: assessment lookup (EXAMPLE: applicants column AB).
    queueSheet.getRange(rowNum, 5).setFormula(
      "=IFERROR(ARRAYFORMULA(INDEX(" + A + "!AB:AB,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(A" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))),\"\")");
    // Column F: Done/Not Yet based on presence in import or stage-2 sheet.
    queueSheet.getRange(rowNum, 6).setFormula(
      "=IF(A" + rowNum + "=\"\",\"\",IF(SUMPRODUCT((SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + IMP + "!A:A)),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(A" + rowNum + ")),CHAR(160),\"\"),\" \",\"\"))*1)>=1,\"Done\",IF(SUMPRODUCT((SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + S2 + "!C:C)),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(A" + rowNum + ")),CHAR(160),\"\"),\" \",\"\"))*1)>=1,\"Done\",\"Not Yet\")))");
    queueSheet.getRange(rowNum, 7).setValue(intName);
    queueSheet.getRange(rowNum, 8).setFormula("=IF(F" + rowNum + "=\"Not Yet\",FALSE,TRUE)");
    queueSheet.getRange(rowNum, 9).setValue(today);
  }
  SpreadsheetApp.flush();

  notifyAdmin_("Process: Stage 1 → Review Queue", cfg.ADMIN_EMAIL);
  ui.alert("Done. " + assignments.length + " candidate(s) added to '" + cfg.SHEET_QUEUE + "'.");
}


