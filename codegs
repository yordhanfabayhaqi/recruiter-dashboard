// ════════════════════════════════════════════════════════════
// CONFIG LAYER (PropertiesService-backed)
// ────────────────────────────────────────────────────────────
// Every secret / ID / email / rate is stored in Script Properties and
// entered by the user through the ⚙️ Setup menu. Code reads them at
// runtime via getConfig_(). Nothing sensitive lives in source.
// ════════════════════════════════════════════════════════════

// Property keys used in PropertiesService.getScriptProperties().
var PROP_KEYS = {
  API_KEY: "API_KEY",                 // AI provider API key (kept out of source)
  MODEL: "MODEL",                     // AI model string
  ADMIN_EMAIL: "ADMIN_EMAIL",         // where audit/log copies go
  EMAIL_DOMAIN: "EMAIL_DOMAIN",       // restrict quick-send recipients to this domain
  CC_EMAILS: "CC_EMAILS",             // optional comma-separated CC list
  PAY_RATE: "PAY_RATE",               // per-interview fee (number)
  CURRENCY: "CURRENCY",               // currency prefix label, e.g. "$"
  PROGRAM_START: "PROGRAM_START",     // ISO date; rows before this are treated as legacy
  STAGE2_START: "STAGE2_START",       // ISO date; stage-2 counting starts here
  SHEET_APPLICANTS: "SHEET_APPLICANTS",
  SHEET_QUEUE: "SHEET_QUEUE",
  SHEET_STAGE2: "SHEET_STAGE2",
  SHEET_OFFERS: "SHEET_OFFERS",
  SHEET_ROSTER: "SHEET_ROSTER",
  SHEET_IMPORT: "SHEET_IMPORT",
};

// Safe generic defaults so the template runs before full configuration.
var CONFIG_DEFAULTS = {
  API_KEY: "",
  MODEL: "",                          // e.g. a chat-completions model string; set via Setup
  ADMIN_EMAIL: "user@example.com",
  EMAIL_DOMAIN: "@example.com",
  CC_EMAILS: "",
  PAY_RATE: "10000",
  CURRENCY: "$",
  PROGRAM_START: "2020-01-01",
  STAGE2_START: "2020-01-01",
  SHEET_APPLICANTS: "Applicants",
  SHEET_QUEUE: "Review Queue",
  SHEET_STAGE2: "Stage 2 Interviews",
  SHEET_OFFERS: "Offers",
  SHEET_ROSTER: "Reviewers",
  SHEET_IMPORT: "Imported Interviews",
};

function getConfig_() {
  var props = PropertiesService.getScriptProperties();
  var stored = props.getProperties();
  var cfg = {};
  Object.keys(CONFIG_DEFAULTS).forEach(function (k) {
    cfg[k] = (stored[k] !== undefined && stored[k] !== "") ? stored[k] : CONFIG_DEFAULTS[k];
  });
  cfg.PAY_RATE = parseInt(cfg.PAY_RATE, 10) || 10000;
  cfg.PROGRAM_START_DATE = parseISO_(cfg.PROGRAM_START);
  cfg.STAGE2_START_DATE = parseISO_(cfg.STAGE2_START);
  return cfg;
}

function saveConfig_(key, value) {
  PropertiesService.getScriptProperties().setProperty(key, value);
}

function parseISO_(iso) {
  var d = new Date(iso);
  return isNaN(d.getTime()) ? new Date(2020, 0, 1) : d;
}


// ════════════════════════════════════════════════════════════
// EXAMPLE SHEET SCHEMA  ── ADAPT THIS TO YOUR OWN SPREADSHEET ──
// ────────────────────────────────────────────────────────────
// These are 1-based column positions on the main "Applicants" sheet.
// Column offsets are structural, not secret, so they live in code — but
// this layout is ONLY AN EXAMPLE. Whoever adopts this template must remap
// these numbers (and the STATUS/ROLE string values below) to match their
// real sheet. Header labels are intentionally generic.
// ════════════════════════════════════════════════════════════
var COLUMNS = {
  TIMESTAMP: 1,       // A  - submission time
  NAME: 2,            // B  - Candidate Name
  RESPONSE: 3,        // C  - Stage-1 outcome (proceed / withdraw / legacy)
  SOURCE: 4,          // D  - Channel / source label
  REVIEWER: 5,        // E  - Stage-1 reviewer name
  VERDICT: 6,         // F  - Screening verdict
  CERT_FLAG: 22,      // V  - "has active certification" flag (example)
  PHONE: 25,          // Y  - Contact number
  ASSESS_DONE: 27,    // AA - Assessment attempted? (DONE / NO)
  ASSESSMENT: 28,     // AB - Assessment result
  SENT_STAGE2: 29,    // AC - Sent to stage-2 interview? (YES)
  MGR_ATTEND: 32,     // AF - Stage-2 attendance marker
  MGR_STATUS: 33,     // AG - Stage-2 (manager) verdict
  TO_OFFERS: 34,      // AH - Copied to Offers? (Done)
  OFFER_RESULT: 35,   // AI - Offer result (Accept / Reject)
  OFFER_NOTES: 36,    // AJ - Offer notes
};

// Example status / label VALUES. Must match the literal strings in your sheet.
// Replace freely; nothing here is required vocabulary.
var STATUS = {
  RESPONSE_PROCEED: "Yes - proceed to interview",
  RESPONSE_LEGACY: "Processed before program start",
  VERDICT_PASS_TOKEN: "passed",                 // substring match, case-insensitive
  VERDICT_FAIL: ["FAILED: Screening", "FAILED: Over age limit", "FAILED: Already employed"],
  ASSESS_NOT_DONE: "NO",
  ASSESS_PASS: ["passed", "passed with warning"], // lowercase compare
  SENT_YES: "YES",
  STAGE2_PASS_TOKEN: "pass",                     // substring; excludes rows containing "not"
  STAGE2_PASS_STATUSES: [
    "1 - PASS, Priority",
    "2 - PASS, Needs Training",
    "3 - PASS, Can Wait",
  ],
  OFFER_ACCEPT: "Accept",
  TO_OFFERS_DONE: "Done",
};

// Example role classification. Replace with your own neutral role labels.
var ROLE = {
  CERTIFIED: "Certified Role",
  GENERAL_A: "General Role A",
  GENERAL_B: "General Role B",
  CERT_TOKEN: "active certification",  // substring in CERT_FLAG cell
  CHANNEL_A_TOKEN: "channel a",        // substring in SOURCE cell -> GENERAL_A
  CHANNEL_B_TOKEN: "channel b",        // substring in SOURCE cell -> GENERAL_B
};


