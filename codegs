function getRoster_() {
  var cfg = getConfig_();
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(cfg.SHEET_ROSTER);
  if (!sheet) return { screeningMap: {}, interviewMap: {} };
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return { screeningMap: {}, interviewMap: {} };

  var rows = sheet.getRange(2, 1, lastRow - 1, 4).getValues();
  var screeningMap = {}, interviewMap = {};
  rows.forEach(function (row) {
    var name = String(row[0]).trim(), email = String(row[1]).trim();
    var stage = String(row[2]).trim().toLowerCase();
    var active = String(row[3]).trim().toUpperCase() === "YES";
    if (name === "" || !active) return;
    var entry = { name: name, email: email, stage: stage };
    if (stage === "screening") screeningMap[name] = entry;
    else if (stage === "interview") interviewMap[name] = entry;
  });
  return { screeningMap: screeningMap, interviewMap: interviewMap };
}


