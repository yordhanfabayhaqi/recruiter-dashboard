// INTERVIEW HEALTH CHECK-UP
// ════════════════════════════════════════════════════════════

function interviewHealthCheckup() {
  var cfg = getConfig_();
  var reportName = "Interview Health Check-up";
  var recipientEmail = promptRecipientEmail_(reportName);
  if (!recipientEmail) return;

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var weeks = buildWeekly_(cfg, data);
  if (weeks.length === 0) { SpreadsheetApp.getUi().alert("No interview data since program start."); return; }

  var currentWeekKey = weekKeyOf_(new Date());
  var completedWeeks = weeks.filter(function (w, idx) { return w.key !== currentWeekKey && idx !== 0; });
  var currentWeek = weeks.filter(function (w) { return w.key === currentWeekKey; })[0];
  if (completedWeeks.length === 0) { SpreadsheetApp.getUi().alert("Need at least 2 completed weeks."); return; }

  var bestWeek = completedWeeks[0], worstWeek = completedWeeks[0], totCand = 0, totInt = 0;
  completedWeeks.forEach(function (w) {
    if (w.candidates > bestWeek.candidates) bestWeek = w;
    if (w.candidates < worstWeek.candidates) worstWeek = w;
    totCand += w.candidates; totInt += w.reviewerCount;
  });
  var avgCand = totCand / completedWeeks.length;
  var avgInt = totInt / completedWeeks.length;
  var avgPer = avgInt > 0 ? avgCand / avgInt : 0;

  var lastWeek = completedWeeks[completedWeeks.length - 1];
  var lastAvgPer = lastWeek.reviewerCount > 0 ? lastWeek.candidates / lastWeek.reviewerCount : 0;
  var health = classifyWeek_(lastWeek.candidates, lastWeek.reviewerCount, lastAvgPer);

  var recommendation;
  if (health.priority >= 3) {
    recommendation = "Operations at normal-to-peak capacity: " + lastWeek.candidates + " candidates by " + lastWeek.reviewerCount + " active reviewer(s) last week. Maintain current roster.";
  } else if (health.priority === 2) {
    var need2 = Math.max(1, Math.ceil((150 - lastWeek.candidates) / 30));
    recommendation = "Below normal capacity: only " + lastWeek.candidates + " candidates by " + lastWeek.reviewerCount + " reviewer(s). Add ~<strong>" + need2 + "</strong> active reviewer(s), or investigate underperformance.";
  } else {
    var need1 = Math.max(2, Math.ceil((150 - lastWeek.candidates) / 30));
    recommendation = "Critical drop: only " + lastWeek.candidates + " candidates by " + lastWeek.reviewerCount + " reviewer(s). Add at least <strong>" + need1 + "</strong> reviewer(s), audit inactivity, and launch an urgent push.";
  }

  var subject = "Recruiter Dashboard: Interview Health Check-up | " + getCurrentDate_();
  var body = "<h2>Interview Health Check-up</h2><p>Weekly analysis since program start. First week excluded as ramp-up.</p>";
  body += "<div style='background:" + health.color + ";color:#fff;padding:16px 20px;margin-top:16px;border-radius:4px;font-family:Arial,sans-serif;'>";
  body += "<h2 style='margin:0 0 8px 0;color:#fff;'>" + health.label.toUpperCase() + "</h2><p style='margin:0;font-size:14px;line-height:1.6;'>" + recommendation + "</p></div>";

  var cell = "padding:8px 14px;border:1px solid #ddd;", labelCell = cell + "background:#f5f5f5;font-weight:bold;";
  body += "<h3 style='margin-top:24px;'>Overview (excl. first & current week)</h3><table style='border-collapse:collapse;font-family:Arial,sans-serif;font-size:14px;'>";
  body += "<tr><td style='" + labelCell + "'>Completed Weeks</td><td style='" + cell + "'>" + completedWeeks.length + "</td></tr>";
  body += "<tr><td style='" + labelCell + "'>Avg Candidates / Week</td><td style='" + cell + "'>" + avgCand.toFixed(1) + "</td></tr>";
  body += "<tr><td style='" + labelCell + "'>Avg Reviewers / Week</td><td style='" + cell + "'>" + avgInt.toFixed(1) + "</td></tr>";
  body += "<tr><td style='" + labelCell + "'>Avg Candidates / Reviewer</td><td style='" + cell + "'>" + avgPer.toFixed(1) + "</td></tr></table>";

  body += "<h3 style='margin-top:24px;'>Best Week</h3>" + buildWeekCard_(bestWeek, "#d4edda");
  body += "<h3 style='margin-top:24px;'>Worst Week</h3>" + buildWeekCard_(worstWeek, "#fadbd8");
  body += "<h3 style='margin-top:24px;'>Last Completed Week</h3>" + buildWeekCard_(lastWeek, "#e3f0fc");
  if (currentWeek) body += "<h3 style='margin-top:24px;'>Current Week (In Progress)</h3>" + buildWeekCard_(currentWeek, "#fff3cd");

  body += "<br><p style='color:#888;font-size:12px;'>Generated at " + getCurrentTime_() + " | Sent to " + recipientEmail + "</p>";

  sendEmailTo_(recipientEmail, subject, body);
  notifyAdmin_(reportName, recipientEmail);
  SpreadsheetApp.getUi().alert("Health Check-up sent to " + recipientEmail);
}

function buildWeekly_(cfg, data) {
  var weekMap = {};
  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    if (String(row[COLUMNS.NAME - 1]).trim() === "") continue;
    var ts = row[COLUMNS.TIMESTAMP - 1];
    if (!ts) continue;
    var date = new Date(ts);
    if (isNaN(date.getTime()) || date < cfg.PROGRAM_START_DATE) continue;
    var reviewer = String(row[COLUMNS.REVIEWER - 1]).trim();
    if (reviewer === "" || reviewer === "-") continue;

    var key = weekKeyOf_(date);
    if (!weekMap[key]) weekMap[key] = { start: weekStartOf_(date), candidates: 0, reviewers: {} };
    weekMap[key].candidates++;
    weekMap[key].reviewers[reviewer] = true;
  }
  return Object.keys(weekMap).sort().map(function (k) {
    return { key: k, start: weekMap[k].start, candidates: weekMap[k].candidates,
      reviewerCount: Object.keys(weekMap[k].reviewers).length, reviewers: Object.keys(weekMap[k].reviewers) };
  });
}

function weekStartOf_(date) {
  var dow = date.getDay(), fromMon = dow === 0 ? 6 : dow - 1;
  var ws = new Date(date); ws.setDate(date.getDate() - fromMon); ws.setHours(0, 0, 0, 0);
  return ws;
}
function weekKeyOf_(date) {
  return Utilities.formatDate(weekStartOf_(date), Session.getScriptTimeZone(), "yyyy-MM-dd");
}

function classifyWeek_(c, ic, ap) {
  if (c >= 200 && ic >= 6 && ap >= 40) return { label: "Very Healthy", color: "#27ae60", priority: 4 };
  if (c >= 150 && ic >= 4 && ap >= 30) return { label: "Healthy", color: "#2ecc71", priority: 3 };
  if (c >= 100 && ic >= 2 && ap >= 25) return { label: "At Risk", color: "#e67e22", priority: 2 };
  return { label: "Heavy Risk", color: "#dc3545", priority: 1 };
}

function buildWeekCard_(week, bgColor) {
  var label = Utilities.formatDate(week.start, Session.getScriptTimeZone(), "dd MMM yyyy");
  var avgPer = week.reviewerCount > 0 ? (week.candidates / week.reviewerCount).toFixed(1) : "0";
  var html = "<div style='background:" + bgColor + ";padding:12px 16px;margin-top:8px;border-left:4px solid #555;font-family:Arial,sans-serif;font-size:14px;'>";
  html += "<strong>Week of " + label + "</strong><br>Candidates: <strong>" + week.candidates + "</strong><br>";
  html += "Active reviewers: <strong>" + week.reviewerCount + "</strong> (" + week.reviewers.join(", ") + ")<br>Avg per reviewer: <strong>" + avgPer + "</strong></div>";
  return html;
}


