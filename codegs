// STAGE-1 FOLLOW-UP RECAP  (per reviewer)
// ════════════════════════════════════════════════════════════

function sendStage1FollowUpRecap() {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();

  var roster = getRoster_();
  var screeners = Object.keys(roster.screeningMap);
  if (screeners.length === 0) { ui.alert("No active screening reviewers in the roster."); return; }

  var list = "";
  screeners.forEach(function (f, i) { list += (i + 1) + ". " + f + "\n"; });
  var sel = ui.prompt("Select Reviewer", "Type a number, or 'all':\n\n" + list, ui.ButtonSet.OK_CANCEL);
  if (sel.getSelectedButton() !== ui.Button.OK) return;
  var input = sel.getResponseText().trim().toLowerCase();
  var selected = [];
  if (input === "all") selected = screeners;
  else { var n = parseInt(input, 10); if (isNaN(n) || n < 1 || n > screeners.length) { ui.alert("Invalid selection."); return; } selected = [screeners[n - 1]]; }

  var mode = ui.prompt("Recipient", "Type a full email to test, or 'send' to email each reviewer.", ui.ButtonSet.OK_CANCEL);
  if (mode.getSelectedButton() !== ui.Button.OK) return;
  var modeInput = mode.getResponseText().trim();
  var sendReal = modeInput.toLowerCase() === "send";
  var testEmail = sendReal ? "" : modeInput;
  if (!sendReal && (testEmail === "" || testEmail.indexOf("@") === -1)) { ui.alert("Invalid email."); return; }

  var period = payPeriodFromPrompt_(ui);
  if (!period) return;

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var cc = cfg.CC_EMAILS || null;
  var FYI = [STATUS.RESPONSE_LEGACY, "Withdraw", "No response / Ghosting"];
  var sent = 0, results = [];

  selected.forEach(function (reviewerName) {
    var paid = [], fyi = [], paidCount = 0;
    for (var i = 0; i < data.length; i++) {
      var row = data[i];
      if (String(row[COLUMNS.REVIEWER - 1]).trim() !== reviewerName) continue;
      var name = String(row[COLUMNS.NAME - 1]).trim(); if (name === "") continue;
      var ts = row[COLUMNS.TIMESTAMP - 1]; if (!ts) continue;
      var d = new Date(ts); if (isNaN(d.getTime()) || d < period.start || d > period.end) continue;

      var status = String(row[COLUMNS.RESPONSE - 1]).trim();
      var entry = { name: name, phone: String(row[COLUMNS.PHONE - 1]).trim(), source: String(row[COLUMNS.SOURCE - 1]).trim(),
        verdict: String(row[COLUMNS.VERDICT - 1]).trim(), date: formatTimestamp_(ts) };
      if (status === STATUS.RESPONSE_PROCEED) { paid.push(entry); paidCount++; }
      else if (FYI.indexOf(status) !== -1) { entry.reason = status; fyi.push(entry); }
    }
    var fee = paidCount * cfg.PAY_RATE;
    var recipient = sendReal ? (roster.screeningMap[reviewerName].email || "") : testEmail;
    if (recipient === "" || recipient.indexOf("@") === -1) { results.push({ name: reviewerName, status: "Skipped — no email" }); return; }

    var isTest = !sendReal;
    var cell = "padding:8px 12px;border:1px solid #ddd;text-align:left;font-size:13px;", headerCell = cell + "background:#f5f5f5;font-weight:bold;";
    var body = "<div style='font-family:Arial,sans-serif;font-size:14px;line-height:1.6;color:#333;'>";
    if (isTest) body += "<div style='background:#fff3cd;border:1px solid #ffc107;padding:12px;margin-bottom:16px;border-radius:4px;'><strong>TEST MODE</strong><br>Production recipient: <strong>" + (roster.screeningMap[reviewerName].email || "(no email)") + "</strong></div>";
    body += "<h2 style='color:#2c3e50;margin-bottom:4px;'>Screening Follow-up Recap</h2><p>Dear <strong>" + reviewerName + "</strong>,</p>";
    body += "<p>Summary of your screening interviews for this period.</p>";
    body += "<div style='background:#e3f0fc;padding:16px 20px;border-left:4px solid #3498db;margin:20px 0;border-radius:4px;'><div style='font-size:13px;color:#666;'>Paid interviews: <strong>" + paidCount + "</strong></div><div style='font-size:20px;font-weight:bold;color:#27ae60;margin-top:8px;'>Estimated Fee: " + money_(cfg, fee) + "</div></div>";

    body += "<h3 style='color:#27ae60;margin-top:24px;'>Paid Interviews (" + paid.length + ")</h3>";
    if (paid.length === 0) body += "<p style='color:#888;font-style:italic;'>None yet.</p>";
    else {
      body += "<table style='border-collapse:collapse;width:100%;'><tr><th style='" + headerCell + "'>#</th><th style='" + headerCell + "'>Name</th><th style='" + headerCell + "'>Contact</th><th style='" + headerCell + "'>Source</th><th style='" + headerCell + "'>Verdict</th><th style='" + headerCell + "'>Date</th></tr>";
      paid.forEach(function (c, i) { body += "<tr style='background:" + (i % 2 === 0 ? "#fff" : "#fafafa") + ";'><td style='" + cell + "'>" + (i + 1) + "</td><td style='" + cell + "'><strong>" + c.name + "</strong></td><td style='" + cell + "'>" + c.phone + "</td><td style='" + cell + "'>" + c.source + "</td><td style='" + cell + "'>" + c.verdict + "</td><td style='" + cell + "'>" + c.date + "</td></tr>"; });
      body += "</table>";
    }

    body += "<h3 style='color:#888;margin-top:24px;'>FYI — Not Counted (" + fyi.length + ")</h3>";
    if (fyi.length === 0) body += "<p style='color:#888;font-style:italic;'>None.</p>";
    else {
      body += "<p style='color:#666;font-size:13px;'>Shown for transparency; not counted toward fee.</p><table style='border-collapse:collapse;width:100%;'><tr><th style='" + headerCell + "'>#</th><th style='" + headerCell + "'>Name</th><th style='" + headerCell + "'>Contact</th><th style='" + headerCell + "'>Status</th><th style='" + headerCell + "'>Date</th></tr>";
      fyi.forEach(function (c, i) { body += "<tr style='background:" + (i % 2 === 0 ? "#fff" : "#fafafa") + ";'><td style='" + cell + "'>" + (i + 1) + "</td><td style='" + cell + "'>" + c.name + "</td><td style='" + cell + "'>" + c.phone + "</td><td style='" + cell + "'>" + c.reason + "</td><td style='" + cell + "'>" + c.date + "</td></tr>"; });
      body += "</table>";
    }
    body += "<p style='margin-top:24px;'>Questions or corrections: " + cfg.ADMIN_EMAIL + ".</p><p>Thank you.</p><p><strong>People Team</strong></p></div>";

    try {
      sendEmailTo_(recipient, (isTest ? "[TEST] " : "") + "Follow-up Recap — " + getCurrentDate_(), body, cc);
      results.push({ name: reviewerName, status: "Sent to " + recipient + " (Paid:" + paidCount + " FYI:" + fyi.length + " Fee:" + money_(cfg, fee) + ")" }); sent++;
    } catch (e) { results.push({ name: reviewerName, status: "Error: " + e.message }); }
  });

  var summary = sent + "/" + selected.length + " recap(s) sent.\n\n";
  results.forEach(function (r) { summary += r.name + ": " + r.status + "\n"; });
  notifyAdmin_("Stage-1 Follow-up Recap" + (sendReal ? "" : " [TEST]"), cfg.ADMIN_EMAIL);
  ui.alert("Stage-1 Follow-up Recap", summary, ui.ButtonSet.OK);
}


