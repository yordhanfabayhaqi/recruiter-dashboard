// ── Table builders ──────────────────────────────────────────

function groupBy_(rows, key) {
  var grouped = {};
  rows.forEach(function (r) { var k = r[key]; if (!grouped[k]) grouped[k] = []; grouped[k].push(r); });
  return grouped;
}

function buildTable_(results, columns) {
  var cellStyle = "padding:8px 12px;border:1px solid #ddd;text-align:left;";
  var headerStyle = cellStyle + "background:#f5f5f5;font-weight:bold;";
  var html = "<table style='border-collapse:collapse;width:100%;font-family:Arial,sans-serif;font-size:14px;'><tr>";
  columns.forEach(function (c) { html += "<th style='" + headerStyle + "'>" + c.header + "</th>"; });
  html += "</tr>";
  results.forEach(function (r, idx) {
    html += "<tr style='background:" + (idx % 2 === 0 ? "#fff" : "#fafafa") + ";'>";
    columns.forEach(function (c) { html += "<td style='" + cellStyle + "'>" + (c.key === "_index" ? idx + 1 : (r[c.key] || "")) + "</td>"; });
    html += "</tr>";
  });
  return html + "</table>";
}

function buildGroupedTable_(grouped, groupLabel, columns) {
  var cellStyle = "padding:8px 12px;border:1px solid #ddd;text-align:left;";
  var headerStyle = cellStyle + "background:#f5f5f5;font-weight:bold;";
  var html = "";
  for (var group in grouped) {
    if (!grouped.hasOwnProperty(group)) continue;
    var candidates = grouped[group];
    html += "<h3 style='margin-top:20px;'>" + groupLabel + ": " + group + " (" + candidates.length + ")</h3>";
    html += "<table style='border-collapse:collapse;width:100%;font-family:Arial,sans-serif;font-size:14px;'><tr>";
    columns.forEach(function (c) { html += "<th style='" + headerStyle + "'>" + c.header + "</th>"; });
    html += "</tr>";
    candidates.forEach(function (r, idx) {
      html += "<tr style='background:" + (idx % 2 === 0 ? "#fff" : "#fafafa") + ";'>";
      columns.forEach(function (c) { html += "<td style='" + cellStyle + "'>" + (c.key === "_index" ? idx + 1 : (r[c.key] || "")) + "</td>"; });
      html += "</tr>";
    });
    html += "</table>";
  }
  return html;
}


