function processQueueToOffers() {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();
  var ss = SpreadsheetApp.getActiveSpreadsheet();

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var offersSheet = ss.getSheetByName(cfg.SHEET_OFFERS);
  if (!offersSheet) { ui.alert("Sheet '" + cfg.SHEET_OFFERS + "' not found."); return; }

  var offersLastRow = findLastRowByColumn_(offersSheet, 2);
  var offersData = offersLastRow >= 2 ? offersSheet.getRange(2, 1, offersLastRow - 1, 6).getValues() : [];
  var offersMap = {};
  offersData.forEach(function (r) { var n = norm_(r[1]); if (n !== "") offersMap[n] = true; });

  var unassigned = [];
  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    var mgrStatus = String(row[COLUMNS.MGR_STATUS - 1]).trim();
    var offerResult = String(row[COLUMNS.OFFER_RESULT - 1]).trim();
    var offerNotes = String(row[COLUMNS.OFFER_NOTES - 1]).trim();
    if (STATUS.STAGE2_PASS_STATUSES.indexOf(mgrStatus) !== -1 && offerResult === "" && offerNotes === "") {
      var name = String(row[COLUMNS.NAME - 1]).trim();
      if (offersMap[norm_(name)]) continue;
      unassigned.push(name);
    }
  }
  if (unassigned.length === 0) { ui.alert("No new candidates. All eligible are already in Offers."); return; }

  var preview = "Found " + unassigned.length + " candidate(s) not yet in Offers:\n\n";
  unassigned.forEach(function (n, i) { if (i < 20) preview += (i + 1) + ". " + n + "\n"; });
  if (unassigned.length > 20) preview += "... and " + (unassigned.length - 20) + " more\n";
  preview += "\nWrite " + unassigned.length + " row(s) to '" + cfg.SHEET_OFFERS + "'?";
  if (ui.alert("Process: Queue → Offers", preview, ui.ButtonSet.YES_NO) !== ui.Button.YES) return;

  var startRow = offersLastRow + 1;
  var today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MMM-yyyy");
  var A = q_(cfg.SHEET_APPLICANTS);

  for (var a = 0; a < unassigned.length; a++) {
    var rowNum = startRow + a, cand = unassigned[a];
    offersSheet.getRange(rowNum, 1).setValue(today);
    offersSheet.getRange(rowNum, 2).setValue(cand);
    // Column C: certification flag lookup (EXAMPLE: applicants column V).
    offersSheet.getRange(rowNum, 3).setFormula(
      "=IFERROR(ARRAYFORMULA(INDEX(" + A + "!V:V,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(B" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))),\"\")");
    // Column D: role classification from cert flag + channel (EXAMPLE schema).
    offersSheet.getRange(rowNum, 4).setFormula(
      "=IF(B" + rowNum + "=\"\",\"\",IFERROR(IF(ISNUMBER(SEARCH(\"" + ROLE.CERT_TOKEN + "\",C" + rowNum + ")),\"" + ROLE.CERTIFIED + "\",IF(ISNUMBER(SEARCH(\"" + ROLE.CHANNEL_A_TOKEN + "\",ARRAYFORMULA(INDEX(" + A + "!D:D,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(B" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))))),\"" + ROLE.GENERAL_A + "\",\"" + ROLE.GENERAL_B + "\")),\"" + ROLE.GENERAL_B + "\"))");
    // Column E: age/attribute lookup (EXAMPLE: applicants column H).
    offersSheet.getRange(rowNum, 5).setFormula(
      "=IFERROR(ARRAYFORMULA(INDEX(" + A + "!H:H,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(B" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))),\"\")");
    // Column F: contact lookup (EXAMPLE: applicants column Y).
    offersSheet.getRange(rowNum, 6).setFormula(
      "=IFERROR(ARRAYFORMULA(INDEX(" + A + "!Y:Y,MATCH(1,(SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(B" + rowNum + ")),CHAR(160),\"\"),\" \",\"\")=SUBSTITUTE(SUBSTITUTE(LOWER(TRIM(" + A + "!B:B)),CHAR(160),\"\"),\" \",\"\"))*1,0))),\"\")");
  }
  SpreadsheetApp.flush();

  notifyAdmin_("Process: Queue → Offers", cfg.ADMIN_EMAIL);
  ui.alert("Done. " + unassigned.length + " candidate(s) added to '" + cfg.SHEET_OFFERS + "'.");
}


// ════════════════════════════════════════════════════════════
// PAYROLL RECAP (summary for a pay period)
// ════════════════════════════════════════════════════════════

function payPeriodFromPrompt_(ui) {
  var r = ui.prompt("Payroll Period", "Enter disbursement month as MM YYYY.\nExample: 04 2026 (period 21 Mar – 20 Apr).", ui.ButtonSet.OK_CANCEL);
  if (r.getSelectedButton() !== ui.Button.OK) return null;
  var parts = r.getResponseText().trim().split(/\s+/);
  if (parts.length !== 2) { ui.alert("Invalid format. Use: MM YYYY"); return null; }
  var m = parseInt(parts[0], 10), y = parseInt(parts[1], 10);
  if (isNaN(m) || isNaN(y) || m < 1 || m > 12) { ui.alert("Invalid month/year."); return null; }
  return {
    start: new Date(y, m - 2, 21, 0, 0, 0),
    end: new Date(y, m - 1, 20, 23, 59, 59),
    label: Utilities.formatDate(new Date(y, m - 1, 1), Session.getScriptTimeZone(), "MMMM yyyy"),
  };
}

function sendPayrollRecap() {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();
  var period = payPeriodFromPrompt_(ui);
  if (!period) return;
  var cutoffLabel = Utilities.formatDate(period.start, Session.getScriptTimeZone(), "dd MMM yyyy") + " – " + Utilities.formatDate(period.end, Session.getScriptTimeZone(), "dd MMM yyyy");

  var recipientEmail = promptRecipientEmail_("Payroll Recap");
  if (!recipientEmail) return;

  var roster = getRoster_();
  var screeners = Object.keys(roster.screeningMap);
  var interviewers = Object.keys(roster.interviewMap);

  var applicants = getSheetData_(cfg.SHEET_APPLICANTS);
  var scStats = {};
  screeners.forEach(function (n) { scStats[n] = { submitted: 0, interviewed: 0, passed: 0, failed: 0 }; });
  for (var i = 0; i < applicants.length; i++) {
    var row = applicants[i];
    var reviewer = String(row[COLUMNS.REVIEWER - 1]).trim();
    if (!(reviewer in scStats)) continue;
    var ts = row[COLUMNS.TIMESTAMP - 1]; if (!ts) continue;
    var d = new Date(ts); if (isNaN(d.getTime()) || d < period.start || d > period.end) continue;
    var status = String(row[COLUMNS.RESPONSE - 1]).trim();
    var verdict = String(row[COLUMNS.VERDICT - 1]).trim().toLowerCase();
    scStats[reviewer].submitted++;
    if (status === STATUS.RESPONSE_PROCEED) {
      scStats[reviewer].interviewed++;
      if (verdict.indexOf(STATUS.VERDICT_PASS_TOKEN) !== -1) scStats[reviewer].passed++; else scStats[reviewer].failed++;
    }
  }

  var stage2 = getSheetData_(cfg.SHEET_STAGE2);
  var intStats = {};
  interviewers.forEach(function (n) { intStats[n] = { interviewed: 0 }; });
  for (var j = 0; j < stage2.length; j++) {
    var r2 = stage2[j];
    var interviewer = String(r2[1]).trim();       // EXAMPLE: stage-2 column B = interviewer
    if (!(interviewer in intStats)) continue;
    var ts2 = r2[0]; if (!ts2) continue;          // EXAMPLE: stage-2 column A = timestamp
    var d2 = new Date(ts2); if (isNaN(d2.getTime()) || d2 < cfg.STAGE2_START_DATE || d2 < period.start || d2 > period.end) continue;
    intStats[interviewer].interviewed++;
  }

  var totalScreenerPay = 0, totalInterviewerPay = 0;
  var scEntries = screeners.map(function (n) {
    var s = scStats[n], pay = s.interviewed * cfg.PAY_RATE; totalScreenerPay += pay;
    return { name: n, submitted: s.submitted, interviewed: s.interviewed, passed: s.passed, failed: s.failed,
      pct: s.submitted > 0 ? ((s.interviewed / s.submitted) * 100).toFixed(1) : "0.0", pay: pay };
  }).sort(function (a, b) { return b.interviewed - a.interviewed; });

  var intEntries = interviewers.map(function (n) {
    var s = intStats[n], pay = s.interviewed * cfg.PAY_RATE; totalInterviewerPay += pay;
    return { name: n, interviewed: s.interviewed, pay: pay };
  }).sort(function (a, b) { return b.interviewed - a.interviewed; });

  var grandTotal = totalScreenerPay + totalInterviewerPay;
  var activeSc = scEntries.filter(function (e) { return e.interviewed > 0; });
  var inactiveSc = scEntries.filter(function (e) { return e.interviewed === 0; });

  var cell = "padding:8px 12px;border:1px solid #ddd;text-align:left;font-size:13px;";
  var headerCell = cell + "background:#f5f5f5;font-weight:bold;";
  var numCell = cell + "text-align:center;";

  var body = "<div style='font-family:Arial,sans-serif;font-size:14px;line-height:1.6;color:#333;'>";
  body += "<h2 style='color:#2c3e50;'>Payroll Recap — " + period.label + "</h2>";
  body += "<p><strong>Period:</strong> " + cutoffLabel + "<br><strong>Rate:</strong> " + money_(cfg, cfg.PAY_RATE) + " / interview</p>";

  body += "<div style='background:#2c3e50;color:#fff;padding:20px 24px;border-radius:4px;margin:20px 0;'>";
  body += "<div style='font-size:13px;opacity:0.8;'>Total Disbursement</div><div style='font-size:28px;font-weight:bold;margin-top:4px;'>" + money_(cfg, grandTotal) + "</div>";
  body += "<div style='margin-top:12px;display:flex;gap:24px;'>";
  body += "<div><div style='font-size:11px;opacity:0.7;'>Screening</div><div style='font-size:16px;font-weight:bold;'>" + money_(cfg, totalScreenerPay) + "</div></div>";
  body += "<div><div style='font-size:11px;opacity:0.7;'>Interview</div><div style='font-size:16px;font-weight:bold;'>" + money_(cfg, totalInterviewerPay) + "</div></div>";
  body += "</div></div>";

  var top3 = activeSc.slice(0, 3);
  if (top3.length > 0) {
    body += "<div style='background:#d4edda;padding:14px 18px;border-left:4px solid #27ae60;margin:8px 0;border-radius:4px;'><strong style='color:#155724;'>Top Screeners</strong><br>";
    top3.forEach(function (e, i) { body += (i + 1) + ". <strong>" + e.name + "</strong> — " + e.interviewed + " (" + money_(cfg, e.pay) + ")<br>"; });
    body += "</div>";
  }
  if (inactiveSc.length > 0) {
    body += "<div style='background:#f8d7da;padding:14px 18px;border-left:4px solid #dc3545;margin:8px 0;border-radius:4px;'><strong style='color:#721c24;'>Inactive Screeners (0)</strong><br>" + inactiveSc.map(function (e) { return e.name; }).join(", ") + "</div>";
  }

  body += "<h3 style='margin-top:28px;color:#2c3e50;'>Screening Stage</h3><table style='border-collapse:collapse;width:100%;'>";
  body += "<tr><th style='" + headerCell + "'>#</th><th style='" + headerCell + "'>Name</th><th style='" + headerCell + "'>Submitted</th><th style='" + headerCell + "'>Interviewed</th><th style='" + headerCell + "'>%</th><th style='" + headerCell + "'>Passed</th><th style='" + headerCell + "'>Failed</th><th style='" + headerCell + "'>Pay</th></tr>";
  scEntries.forEach(function (e, i) {
    var dim = e.interviewed === 0 ? "color:#ccc;" : "";
    body += "<tr style='background:" + (i % 2 === 0 ? "#fff" : "#fafafa") + ";" + dim + "'><td style='" + numCell + "'>" + (i + 1) + "</td><td style='" + cell + "'><strong>" + e.name + "</strong></td><td style='" + numCell + "'>" + e.submitted + "</td><td style='" + numCell + "font-weight:bold;'>" + e.interviewed + "</td><td style='" + numCell + "'>" + e.pct + "%</td><td style='" + numCell + "color:#27ae60;'>" + e.passed + "</td><td style='" + numCell + "color:#dc3545;'>" + e.failed + "</td><td style='" + cell + "font-weight:bold;'>" + money_(cfg, e.pay) + "</td></tr>";
  });
  body += "</table>";

  body += "<h3 style='margin-top:28px;color:#2c3e50;'>Interview Stage</h3><table style='border-collapse:collapse;width:100%;'>";
  body += "<tr><th style='" + headerCell + "'>#</th><th style='" + headerCell + "'>Name</th><th style='" + headerCell + "'>Interviews</th><th style='" + headerCell + "'>Pay</th></tr>";
  intEntries.forEach(function (e, i) {
    var dim = e.interviewed === 0 ? "color:#ccc;" : "";
    body += "<tr style='background:" + (i % 2 === 0 ? "#fff" : "#fafafa") + ";" + dim + "'><td style='" + numCell + "'>" + (i + 1) + "</td><td style='" + cell + "'><strong>" + e.name + "</strong></td><td style='" + numCell + "font-weight:bold;'>" + e.interviewed + "</td><td style='" + cell + "font-weight:bold;'>" + money_(cfg, e.pay) + "</td></tr>";
  });
  body += "</table>";

  body += "<br><p style='color:#888;font-size:12px;'>Generated at " + getCurrentTime_() + " | Sent to " + recipientEmail + "</p></div>";

  sendEmailTo_(recipientEmail, "Recruiter Dashboard: Payroll Recap — " + period.label + " | " + getCurrentDate_(), body);
  notifyAdmin_("Payroll Recap — " + period.label, recipientEmail);
  ui.alert("Payroll Recap for " + period.label + " sent to " + recipientEmail + ".\nTotal: " + money_(cfg, grandTotal));
}


// ════════════════════════════════════════════════════════════
// INDIVIDUAL REVIEWER REPORT CARDS  (screening stage)
// ════════════════════════════════════════════════════════════

function sendReviewerReportCards() {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();

  var roster = getRoster_();
  var screeners = Object.keys(roster.screeningMap);
  if (screeners.length === 0) { ui.alert("No active screening reviewers in the roster."); return; }

  var list = "";
  screeners.forEach(function (f, i) { list += (i + 1) + ". " + f + "\n"; });
  var sel = ui.prompt("Select Reviewers", "Numbers separated by commas, or 'all':\n\n" + list, ui.ButtonSet.OK_CANCEL);
  if (sel.getSelectedButton() !== ui.Button.OK) return;
  var input = sel.getResponseText().trim().toLowerCase();
  var selected = [];
  if (input === "all") selected = screeners;
  else input.split(",").forEach(function (t) { var idx = parseInt(t.trim(), 10); if (!isNaN(idx) && idx >= 1 && idx <= screeners.length) selected.push(screeners[idx - 1]); });
  if (selected.length === 0) { ui.alert("Invalid selection."); return; }

  var period = payPeriodFromPrompt_(ui);
  if (!period) return;
  var cutoffLabel = Utilities.formatDate(period.start, Session.getScriptTimeZone(), "dd MMM yyyy") + " – " + Utilities.formatDate(period.end, Session.getScriptTimeZone(), "dd MMM yyyy");

  var mode = ui.prompt("Recipient", "Type a full email to test (e.g. user@example.com), or 'send' to email each reviewer's registered address.", ui.ButtonSet.OK_CANCEL);
  if (mode.getSelectedButton() !== ui.Button.OK) return;
  var modeInput = mode.getResponseText().trim();
  var sendReal = modeInput.toLowerCase() === "send";
  var testEmail = sendReal ? "" : modeInput;
  if (!sendReal && (testEmail === "" || testEmail.indexOf("@") === -1)) { ui.alert("Invalid email."); return; }

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var cc = cfg.CC_EMAILS || null;
  var sent = 0, results = [];

  selected.forEach(function (reviewerName) {
    var submitted = 0, interviewed = 0, passed = 0, failed = 0, detail = [];
    for (var i = 0; i < data.length; i++) {
      var row = data[i];
      if (String(row[COLUMNS.REVIEWER - 1]).trim() !== reviewerName) continue;
      var ts = row[COLUMNS.TIMESTAMP - 1]; if (!ts) continue;
      var d = new Date(ts); if (isNaN(d.getTime()) || d < period.start || d > period.end) continue;
      submitted++;
      if (String(row[COLUMNS.RESPONSE - 1]).trim() === STATUS.RESPONSE_PROCEED) {
        interviewed++;
        if (String(row[COLUMNS.VERDICT - 1]).trim().toLowerCase().indexOf(STATUS.VERDICT_PASS_TOKEN) !== -1) passed++; else failed++;
        detail.push({ date: Utilities.formatDate(d, Session.getScriptTimeZone(), "dd MMM yyyy, HH:mm"), sort: d.getTime(),
          name: String(row[COLUMNS.NAME - 1]).trim(), phone: String(row[COLUMNS.PHONE - 1]).trim() });
      }
    }
    detail.sort(function (a, b) { return a.sort - b.sort; });
    var pct = submitted > 0 ? ((interviewed / submitted) * 100).toFixed(1) : "0.0";
    var fee = interviewed * cfg.PAY_RATE;

    var recipient = sendReal ? (roster.screeningMap[reviewerName].email || "") : testEmail;
    if (recipient === "" || recipient.indexOf("@") === -1) { results.push({ name: reviewerName, status: "Skipped — no email" }); return; }

    var isTest = !sendReal;
    var cell = "padding:8px 12px;border:1px solid #ddd;text-align:left;font-size:13px;", headerCell = cell + "background:#f5f5f5;font-weight:bold;";
    var body = "<div style='font-family:Arial,sans-serif;font-size:14px;line-height:1.6;color:#333;'>";
    if (isTest) body += "<div style='background:#fff3cd;border:1px solid #ffc107;padding:12px;margin-bottom:16px;border-radius:4px;'><strong>TEST MODE</strong><br>In production this would go to: <strong>" + (roster.screeningMap[reviewerName].email || "(no email)") + "</strong></div>";
    body += "<h2 style='color:#2c3e50;margin-bottom:4px;'>" + reviewerName + " — Report Card</h2><p style='color:#666;margin-top:0;'>" + period.label + " (" + cutoffLabel + ")</p>";
    body += "<div style='background:#e3f0fc;padding:16px 20px;border-left:4px solid #3498db;margin:20px 0;border-radius:4px;'><div style='font-size:13px;color:#666;'>Total Fee</div><div style='font-size:24px;font-weight:bold;color:#27ae60;'>" + money_(cfg, fee) + "</div></div>";
    body += "<table style='border-collapse:collapse;width:100%;'>";
    body += "<tr><td style='" + headerCell + "'>Submitted</td><td style='" + cell + "'>" + submitted + "</td></tr>";
    body += "<tr><td style='" + headerCell + "'>Interviewed</td><td style='" + cell + "font-weight:bold;'>" + interviewed + "</td></tr>";
    body += "<tr><td style='" + headerCell + "'>Success Rate</td><td style='" + cell + "'>" + pct + "%</td></tr>";
    body += "<tr><td style='" + headerCell + "'>Fee</td><td style='" + cell + "font-weight:bold;'>" + money_(cfg, fee) + "</td></tr>";
    body += "<tr><td style='" + headerCell + "'>Passed</td><td style='" + cell + "color:#27ae60;'>" + passed + "</td></tr>";
    body += "<tr><td style='" + headerCell + "'>Failed</td><td style='" + cell + "color:#dc3545;'>" + failed + "</td></tr></table>";
    body += "<h3 style='margin-top:24px;color:#2c3e50;'>Interview Details (" + detail.length + ")</h3>";
    if (detail.length === 0) body += "<p style='color:#888;font-style:italic;'>No interviews in this period.</p>";
    else {
      body += "<table style='border-collapse:collapse;width:100%;'><tr><th style='" + headerCell + "'>#</th><th style='" + headerCell + "'>Date</th><th style='" + headerCell + "'>Candidate</th><th style='" + headerCell + "'>Contact</th></tr>";
      detail.forEach(function (c, i) { body += "<tr style='background:" + (i % 2 === 0 ? "#fff" : "#fafafa") + ";'><td style='" + cell + "'>" + (i + 1) + "</td><td style='" + cell + "'>" + c.date + "</td><td style='" + cell + "'><strong>" + c.name + "</strong></td><td style='" + cell + "'>" + c.phone + "</td></tr>"; });
      body += "</table>";
    }
    body += "<p style='margin-top:24px;'>Questions or corrections: " + cfg.ADMIN_EMAIL + ".</p><p>Thank you for your work.</p><p><strong>People Team</strong></p></div>";

    try {
      sendEmailTo_(recipient, (isTest ? "[TEST] " : "") + "Report Card — " + period.label + " | " + reviewerName, body, cc);
      results.push({ name: reviewerName, status: "Sent to " + recipient + " — " + interviewed + " interviews, " + money_(cfg, fee) }); sent++;
    } catch (e) { results.push({ name: reviewerName, status: "Error: " + e.message }); }
  });

  var summary = sent + "/" + selected.length + " report(s) sent.\n\n";
  results.forEach(function (r) { summary += r.name + ": " + r.status + "\n"; });
  notifyAdmin_("Reviewer Report Cards" + (sendReal ? "" : " [TEST]"), cfg.ADMIN_EMAIL);
  ui.alert("Reviewer Report Cards", summary, ui.ButtonSet.OK);
}


