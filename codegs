function getSheetData_(sheetName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(sheetName);
  if (!sheet) return [];
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();
  if (lastRow < 2) return [];
  return sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();
}

function findLastRowByColumn_(sheet, colIndex) {
  var data = sheet.getRange(1, colIndex, sheet.getLastRow(), 1).getValues();
  for (var i = data.length - 1; i >= 0; i--) {
    if (String(data[i][0]).trim() !== "") return i + 1;
  }
  return 1;
}

function formatTimestamp_(value) {
  if (!value) return "-";
  try {
    var date = new Date(value);
    if (isNaN(date.getTime())) return String(value);
    return Utilities.formatDate(date, Session.getScriptTimeZone(), "dd MMM yyyy, HH:mm");
  } catch (e) {
    return String(value);
  }
}

function getCurrentTime_() {
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd MMM yyyy, HH:mm");
}

function getCurrentDate_() {
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd MMM yyyy");
}

function formatNumber_(num) {
  return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}

function money_(cfg, num) {
  return cfg.CURRENCY + " " + formatNumber_(num);
}

function sendEmailTo_(recipient, subject, htmlBody, cc) {
  var opts = { htmlBody: htmlBody, name: "Recruiter Dashboard" };
  if (cc) opts.cc = cc;
  GmailApp.sendEmail(recipient, subject, "", opts);
}

function promptRecipientEmail_(reportName) {
  var cfg = getConfig_();
  var ui = SpreadsheetApp.getUi();
  var result = ui.prompt("📧 " + reportName, "Send report to (name before " + cfg.EMAIL_DOMAIN + "):\n\nExample: user", ui.ButtonSet.OK_CANCEL);
  if (result.getSelectedButton() !== ui.Button.OK) return null;

  var input = result.getResponseText().trim().toLowerCase();
  if (input === "") { ui.alert("Email cannot be empty."); return null; }

  var name = input.replace(cfg.EMAIL_DOMAIN, "").replace("@", "");
  if (name === "" || name.indexOf(" ") !== -1) { ui.alert("Invalid name. Type only the part before " + cfg.EMAIL_DOMAIN + "."); return null; }

  var email = name + cfg.EMAIL_DOMAIN;
  var confirm = ui.alert("Confirm", "Send \"" + reportName + "\" to " + email + "?", ui.ButtonSet.YES_NO);
  return confirm === ui.Button.YES ? email : null;
}

function notifyAdmin_(reportName, recipientEmail) {
  var cfg = getConfig_();
  var requester = Session.getActiveUser().getEmail() || "Unknown user";
  if (recipientEmail === cfg.ADMIN_EMAIL && requester === cfg.ADMIN_EMAIL) return;

  var body = "<div style='font-family:Arial,sans-serif;font-size:14px;line-height:1.6;'>";
  body += "<h3>Recruiter Dashboard — Report Log</h3><table style='border-collapse:collapse;'>";
  body += "<tr><td style='padding:4px 12px 4px 0;font-weight:bold;'>Report:</td><td>" + reportName + "</td></tr>";
  body += "<tr><td style='padding:4px 12px 4px 0;font-weight:bold;'>Requested by:</td><td>" + requester + "</td></tr>";
  body += "<tr><td style='padding:4px 12px 4px 0;font-weight:bold;'>Sent to:</td><td>" + recipientEmail + "</td></tr>";
  body += "<tr><td style='padding:4px 12px 4px 0;font-weight:bold;'>Time:</td><td>" + getCurrentTime_() + "</td></tr>";
  body += "</table></div>";

  GmailApp.sendEmail(cfg.ADMIN_EMAIL, "[Log] Recruiter Dashboard: \"" + reportName + "\" sent", "", { htmlBody: body, name: "Recruiter Dashboard" });
}

// Quote a sheet name for use inside an A1 spreadsheet formula.
function q_(name) {
  return "'" + String(name).replace(/'/g, "''") + "'";
}

// Case/space-insensitive normalization used for name matching.
function norm_(s) {
  return String(s).trim().toLowerCase().replace(/\s+/g, "");
}


// ════════════════════════════════════════════════════════════
// PIPELINE REPORT
// ════════════════════════════════════════════════════════════

function emptyBucket_() {
  return { applicant: 0, responded: 0, passedScreening: 0, assessDone: 0, assessPassed: 0, sentStage2: 0, stage2Passed: 0, offered: 0, accepted: 0 };
}

function computeBuckets_(cfg, data) {
  var buckets = { roleGeneral: emptyBucket_(), roleCertified: emptyBucket_(), total: emptyBucket_(), channelA: emptyBucket_(), channelB: emptyBucket_() };

  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    var name = String(row[COLUMNS.NAME - 1]).trim();
    if (name === "") continue;

    var response = String(row[COLUMNS.RESPONSE - 1]).trim();
    if (response === STATUS.RESPONSE_LEGACY) continue;

    var certFlag = String(row[COLUMNS.CERT_FLAG - 1]).trim().toLowerCase();
    var roleBucket = certFlag.indexOf(ROLE.CERT_TOKEN) !== -1 ? "roleCertified" : "roleGeneral";

    var source = String(row[COLUMNS.SOURCE - 1]).trim().toLowerCase();
    var channelBucket = source.indexOf(ROLE.CHANNEL_A_TOKEN) !== -1 ? "channelA" : "channelB";

    var verdict = String(row[COLUMNS.VERDICT - 1]).trim();
    var assessDone = String(row[COLUMNS.ASSESS_DONE - 1]).trim();
    var assessResult = String(row[COLUMNS.ASSESSMENT - 1]).trim().toLowerCase();
    var sentStage2 = String(row[COLUMNS.SENT_STAGE2 - 1]).trim();
    var mgrStatus = String(row[COLUMNS.MGR_STATUS - 1]).trim().toLowerCase();
    var toOffers = String(row[COLUMNS.TO_OFFERS - 1]).trim();
    var offerResult = String(row[COLUMNS.OFFER_RESULT - 1]).trim();

    var targets = [roleBucket, "total", channelBucket];

    targets.forEach(function (b) { buckets[b].applicant++; });

    var responded = response === STATUS.RESPONSE_PROCEED;
    if (responded) targets.forEach(function (b) { buckets[b].responded++; });

    var failedScreen = STATUS.VERDICT_FAIL.indexOf(verdict) !== -1;
    var passedScreening = responded && !failedScreen;
    if (passedScreening) targets.forEach(function (b) { buckets[b].passedScreening++; });

    var assessDoneOk = passedScreening && assessDone === "DONE";
    if (assessDoneOk) targets.forEach(function (b) { buckets[b].assessDone++; });

    var assessPassedOk = assessDoneOk && STATUS.ASSESS_PASS.indexOf(assessResult) !== -1;
    if (assessPassedOk) targets.forEach(function (b) { buckets[b].assessPassed++; });

    var sentStage2Ok = assessPassedOk && sentStage2 === STATUS.SENT_YES;
    if (sentStage2Ok) targets.forEach(function (b) { buckets[b].sentStage2++; });

    var stage2PassedOk = sentStage2Ok && mgrStatus.indexOf(STATUS.STAGE2_PASS_TOKEN) !== -1 && mgrStatus.indexOf("not") === -1;
    if (stage2PassedOk) targets.forEach(function (b) { buckets[b].stage2Passed++; });

    var offeredOk = stage2PassedOk && toOffers === STATUS.TO_OFFERS_DONE;
    if (offeredOk) targets.forEach(function (b) { buckets[b].offered++; });

    var acceptedOk = offeredOk && offerResult === STATUS.OFFER_ACCEPT;
    if (acceptedOk) targets.forEach(function (b) { buckets[b].accepted++; });
  }
  return buckets;
}

var STAGE_ORDER = [
  { key: "applicant", label: "Applicant" },
  { key: "responded", label: "Responded" },
  { key: "passedScreening", label: "Passed Screening" },
  { key: "assessDone", label: "Assessment Done" },
  { key: "assessPassed", label: "Assessment Passed" },
  { key: "sentStage2", label: "Sent to Stage 2" },
  { key: "stage2Passed", label: "Stage 2 Passed" },
  { key: "offered", label: "Offered" },
  { key: "accepted", label: "Accepted" },
];

function generatePipelineReport() {
  var cfg = getConfig_();
  var reportName = "Pipeline Report";
  var recipientEmail = promptRecipientEmail_(reportName);
  if (!recipientEmail) return;

  var data = getSheetData_(cfg.SHEET_APPLICANTS);
  var buckets = computeBuckets_(cfg, data);

  var subject = "Recruiter Dashboard: Pipeline Report | " + getCurrentDate_();
  var body = "<h2>Recruitment Pipeline Report</h2>";
  body += "<p>Cumulative data as of " + getCurrentTime_() + " (excluding legacy rows before program start).</p>";

  body += "<h2 style='margin-top:32px;border-bottom:2px solid #333;padding-bottom:4px;'>By Role</h2>";
  body += buildHorizontalFunnel_([
    { label: ROLE.GENERAL_A + " / " + ROLE.GENERAL_B, counts: buckets.roleGeneral, color: "#e3f0fc" },
    { label: ROLE.CERTIFIED, counts: buckets.roleCertified, color: "#d4edda" },
    { label: "TOTAL", counts: buckets.total, color: "#fff3cd" },
  ]);

  body += "<h2 style='margin-top:32px;border-bottom:2px solid #333;padding-bottom:4px;'>By Channel</h2>";
  body += buildHorizontalFunnel_([
    { label: "Channel A", counts: buckets.channelA, color: "#e8daef" },
    { label: "Channel B", counts: buckets.channelB, color: "#fadbd8" },
  ]);

  body += generateAIInsight_(cfg, buckets);
  body += "<br><p style='color:#888;font-size:12px;'>Generated at " + getCurrentTime_() + " | Sent to " + recipientEmail + "</p>";

  sendEmailTo_(recipientEmail, subject, body);
  notifyAdmin_(reportName, recipientEmail);
  SpreadsheetApp.getUi().alert("Pipeline report sent to " + recipientEmail);
}

function buildHorizontalFunnel_(sections) {
  var cell = "padding:6px 10px;border:1px solid #ddd;text-align:center;font-size:13px;";
  var headerCell = cell + "background:#f5f5f5;font-weight:bold;white-space:nowrap;";
  var labelCell = cell + "font-weight:bold;text-align:left;white-space:nowrap;";

  var html = "<table style='border-collapse:collapse;font-family:Arial,sans-serif;margin-top:12px;'><tr><th style='" + headerCell + "'></th>";
  STAGE_ORDER.forEach(function (s) { html += "<th style='" + headerCell + "'>" + s.label + "</th>"; });
  html += "</tr>";

  sections.forEach(function (section) {
    var counts = section.counts;
    html += "<tr><td style='" + labelCell + "background:" + section.color + ";' rowspan='3'>" + section.label + "</td>";
    STAGE_ORDER.forEach(function (s) { html += "<td style='" + cell + "font-weight:bold;font-size:14px;'>" + (counts[s.key] || 0) + "</td>"; });
    html += "</tr><tr>";
    STAGE_ORDER.forEach(function (s, i) {
      if (i === 0) { html += "<td style='" + cell + "color:#888;'>—</td>"; return; }
      var prev = counts[STAGE_ORDER[i - 1].key] || 0, curr = counts[s.key] || 0;
      var pct = prev === 0 ? "N/A" : ((curr / prev) * 100).toFixed(1) + "%";
      html += "<td style='" + cell + "color:#27ae60;font-size:12px;'>↑ " + pct + "</td>";
    });
    html += "</tr><tr>";
    STAGE_ORDER.forEach(function (s, i) {
      if (i === 0) { html += "<td style='" + cell + "color:#888;'>—</td>"; return; }
      var prev = counts[STAGE_ORDER[i - 1].key] || 0, curr = counts[s.key] || 0;
      if (prev === 0) { html += "<td style='" + cell + "font-size:12px;'>N/A</td>"; return; }
      var dropVal = ((prev - curr) / prev) * 100;
      var color = "#888", weight = "normal";
      if (dropVal > 50) { color = "#dc3545"; weight = "bold"; }
      else if (dropVal > 30) { color = "#e67e22"; weight = "bold"; }
      html += "<td style='" + cell + "color:" + color + ";font-weight:" + weight + ";font-size:12px;'>↓ " + dropVal.toFixed(1) + "%</td>";
    });
    html += "</tr><tr><td colspan='" + (STAGE_ORDER.length + 1) + "' style='border:none;height:8px;'></td></tr>";
  });

  html += "</table>";
  return html;
}


// ── AI INSIGHT (generic chat-completions call) ──────────────
// Uses the API key + model from Setup. Endpoint below is a placeholder;
// point it at your own AI provider and adjust the request/response shape.

function generateAIInsight_(cfg, buckets) {
  if (!cfg.API_KEY || !cfg.MODEL) {
    return "<br><p style='color:#999;font-style:italic;'>AI Insight skipped — API key or model not configured (see ⚙️ Setup).</p>";
  }

  var dataSummary = buildDataSummaryForAI_(buckets);
  var prompt =
    "You are an HR analytics advisor reviewing a generic recruitment pipeline.\n\n" +
    dataSummary + "\n\n" +
    "The pipeline is strictly linear (each stage requires all previous). It ends at " +
    "Offer Accepted; do not speculate about any post-acceptance stage. Write exactly 3 " +
    "plain-text executive insight points (1. 2. 3.), each 2-3 sentences, specific with " +
    "numbers: (1) biggest bottleneck, (2) a comparison insight, (3) one actionable " +
    "recommendation. No markdown, no filler.";

  try {
    // Placeholder endpoint — replace with your AI provider's URL and payload schema.
    var options = {
      method: "post",
      contentType: "application/json",
      headers: { "Authorization": "Bearer " + cfg.API_KEY },
      payload: JSON.stringify({
        model: cfg.MODEL,
        max_tokens: 500,
        messages: [{ role: "user", content: prompt }],
      }),
      muteHttpExceptions: true,
    };
    var response = UrlFetchApp.fetch("https://api.example.com/v1/chat/completions", options);
    var status = response.getResponseCode();
    if (status !== 200) {
      return "<br><p style='color:#cc0000;font-style:italic;'>AI Insight error (" + status + ").</p>";
    }
    var result = JSON.parse(response.getContentText());
    // Adjust this extraction to match your provider's response shape.
    var insightText = (result.choices && result.choices[0] && result.choices[0].message && result.choices[0].message.content)
      ? result.choices[0].message.content
      : (result.content && result.content[0] && result.content[0].text ? result.content[0].text : "");

    var html = "<br><h2 style='margin-top:32px;border-bottom:2px solid #333;padding-bottom:4px;'>AI Executive Insight</h2>";
    html += "<div style='background:#f0f4ff;border-left:4px solid #4a6cf7;padding:16px 20px;margin-top:12px;font-family:Arial,sans-serif;font-size:14px;line-height:1.7;white-space:pre-line;'>" + insightText + "</div>";
    return html;
  } catch (e) {
    return "<br><p style='color:#cc0000;font-style:italic;'>AI Insight error: " + e.message + "</p>";
  }
}

function buildDataSummaryForAI_(buckets) {
  function formatBucket(name, counts) {
    var text = name + ":\n";
    for (var i = 0; i < STAGE_ORDER.length; i++) {
      var s = STAGE_ORDER[i], count = counts[s.key] || 0, convStr = "";
      if (i > 0) {
        var prev = counts[STAGE_ORDER[i - 1].key] || 0;
        var conv = prev === 0 ? "N/A" : ((count / prev) * 100).toFixed(1) + "%";
        var drop = prev === 0 ? "N/A" : (((prev - count) / prev) * 100).toFixed(1) + "%";
        convStr = " (conversion: " + conv + ", drop-off: " + drop + ")";
      }
      text += "  " + s.label + ": " + count + convStr + "\n";
    }
    return text;
  }
  var summary = "";
  summary += formatBucket(ROLE.GENERAL_A + "/" + ROLE.GENERAL_B, buckets.roleGeneral);
  summary += "\n" + formatBucket(ROLE.CERTIFIED, buckets.roleCertified);
  summary += "\n" + formatBucket("TOTAL", buckets.total);
  summary += "\n" + formatBucket("Channel A", buckets.channelA);
  summary += "\n" + formatBucket("Channel B", buckets.channelB);
  return summary;
}


